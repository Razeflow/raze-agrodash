# Browser + middleware + SSR (public)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Use either legacy anon JWT or newer publishable key (not both required)
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Server-side scripts only (e.g. seed-supabase-bulk). Never NEXT_PUBLIC_ or commit real values.
SUPABASE_SERVICE_ROLE_KEY=
